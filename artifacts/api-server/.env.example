# Copy this file to .env and fill in real values, then load it into your
# shell before running `pnpm --filter @workspace/api-server run dev`
# (see the root README.md "Run locally in VSCode" section for exact steps).

# Port the API server listens on.
PORT=8080

# Postgres connection string, e.g.:
# postgresql://USER:PASSWORD@localhost:5432/placepro
DATABASE_URL=

# Secret used to sign JWTs. Any long random string works for local dev.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
