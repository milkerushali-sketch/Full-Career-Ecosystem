# Copy this file to .env and fill in real values, then load it into your
# shell before running `pnpm --filter @workspace/placement-system run dev`
# (see the root README.md "Run locally in VSCode" section for exact steps).

# Port the Vite dev server listens on.
PORT=5173

# Base path the app is served from. Use "/" for local development.
BASE_PATH=/

# Where the frontend's /api requests should be proxied to during local dev
# (must match the API server's PORT above/in artifacts/api-server/.env).
API_PROXY_TARGET=
